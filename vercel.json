
{
   "version": 2,
   "builds": [
      {
         "src": "./server.ts",
         "use": "@vercel/node"
      }
   ],
   "routes": [
      {
         "src": "/(.*)",
         "dest": "/server.html",
         "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
         "headers": { "Access-Control-Allow-Origin": "*" }
      }
   ]
}